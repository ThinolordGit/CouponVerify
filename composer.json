{
    "name": "giftcloud/giftcard-verification",
    "description": "Gift Card Verification Platform with Web Push Notifications",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Development Team",
            "email": "dev@giftcloud.local"
        }
    ],
    "require": {
        "php": ">=8.0",
        "minishlink/web-push": "^7.0",
