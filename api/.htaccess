<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/
    
    # Don't rewrite if it's an actual file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all requests to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
